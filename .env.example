# Copy this file to .env and fill in the values

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL + pgvector via Docker — recommended for this project)
#   docker compose up -d db redis
#   Host: localhost  Port: 5434  (NOT 5432/5433 if you have PostgreSQL 16 / pgAdmin locally)
DATABASE_URL=postgres://bcrdc_user:bcrdc_pass@127.0.0.1:5434/bcrdc_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI (fournisseur IA primaire)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Gemini (fallback gratuit si OpenAI echoue ou n'est pas configure)
#   Cle gratuite : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash

# SMS : mode mock uniquement (aucun fournisseur externe).
# Le code OTP s'affiche directement sur la page de verification.

# App Settings
SITE_URL=http://localhost:8000
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Secret server-side pepper used to hash phone numbers (HMAC-SHA256).
# Generate a random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If left empty, SECRET_KEY is used as a fallback.
PHONE_HASH_PEPPER=
